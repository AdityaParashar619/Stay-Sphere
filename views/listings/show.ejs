<% layout("/layouts/boilerplate") -%>

<div class="row offset-2" id="show" >
    <div class="flash2" style="margin-left:-7rem">
    <% if (success && success.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show col-5 offset-2" role="alert">
            <%= success[0] %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>
            <% if (errors && errors.length > 0) { %>
                <div class="alert alert-danger alert-dismissible fade show col-6 offset-3" role="alert">
                    <%= errors[0] %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>
        </div>
    <div class="col-8">
        <h4>Beautiful place in <%=lists.country%></h4><br>
    <div class="show_card" style="width: 18rem;">
        <img src="<%=lists.image.url%>" class="card-img-top" alt="...">
    </div>

<div class="description">
    <h3> <small class="text-body-secondary" style="color: black!important; text-decoration: underline"><%=lists.title%></small></h3>
    <p>Listing Owned by <%=lists.owner.username%></p>
    <h5> <small class="text-body-secondary"><%=lists.description%></small></h5>
    <p class="lead">In just at the starting rate of &#8377;<%=lists.price.toLocaleString("en-IN")%> only</p>
    <blockquote class="blockquote">
        <p>in the city of dreams <%=lists.location%>,</p>
        <p> <%=lists.country%></p>
    </blockquote>
</div>
        <% if(curUser && curUser._id.equals(lists.owner._id)){ %>
        <div class="btns" >
        <a href="/listings/<%=lists.id%>/edit">
            <button class="show_edit" type="submit" >Edit this list</button>
        </a>
<form action="/listings/<%=lists.id%>?_method=DELETE" method="POST">
    <button class="btn btn-dark" type="submit" style="background-color: grey; border: none">Delete this list</button>
</form>
    </div><%}%>
        <br>
        <% if(curUser) {%>
        <hr>
<!--        making the review section-->
        <div  id="reviews">
            <h4>Leave a Review !!</h4><br>
            <form action="/listings/<%=lists.id%>/reviews" method="POST" novalidate class="needs-validation" >
                <div class="rating ">
                    <label for="rating" class="form-label">Rate Us </label>
<!--                    <input type="range" min="1" max="5" name="review[rating]" id="rating"><br>-->
<!--                -->

                <fieldset class="starability-grow">
                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
                </div>
                <div class="comment">
                    <label for="comment" class="form-label">Your Comment</label>
                    <textarea placeholder="comment here!!" name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
                    <div class="invalid-feedback">
                        Please add some comment !!
                    </div>
                </div>
                <br>
                <button type="submit" class="btn" style="background-color: orangered; color: white">Submit Review</button>
            </form><%}%>
        </div>
        <br>
        <hr>
<!--        showing all reviews-->
<% if(lists.review.length>0) {%>
            <h4>All Reviews :</h4>
        <div class="row">

            <% for (let rev of lists.review) {%>
                <div class="card col-5 ms-3 mb-3 mt-3 pt-3 " >
                    <div class="card-body">
                        <h5 class="card-title">@<%=rev.author.username%></h5>
                        <p class="starability-result card-text " data-rating=<%=rev.rating%>>
                            Rated: 3 stars
                        </p>
<!--                        <p class="card-text">Rating: ⭐</p>-->
                        <p class="card-text">Comment: <%=rev.comment%></p>
                        <p class="card-text"><small>At: <%=rev.created_at%></small></p>
                        <% if(curUser && curUser._id.equals(rev.author._id)){ %>
                        <form action="/listings/<%=lists.id%>/reviews/<%=rev.id%>?_method=DELETE" method="POST" >
                            <button class=" btn btn-sm btn-dark">Delete</button>
                        </form>
                        <%}%>
                    </div>
                </div>
            <%}%>
        </div>
        <%}%>
        <h4> Where you'll see</h4>
        <div class="col-8" id="map"></div>
    </div>
</div>

<script>
    const coordinates = [
        <%= lists.geometry.coordinates[1] %>,
        <%= lists.geometry.coordinates[0] %>
    ];

    const map = L.map("map").setView(coordinates, 9);

    L.tileLayer(
        "https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png"
    ).addTo(map);

    const redIcon = new L.Icon({
        iconUrl: "https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-red.png",
        shadowUrl: "https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png",
        iconSize: [25,41],
        iconAnchor: [12,41],
        popupAnchor: [1,-34],
        shadowSize: [41,41]
    });
    L.marker(coordinates,{icon: redIcon})
        .addTo(map)
        .bindPopup("<%=lists.title%>")

</script>